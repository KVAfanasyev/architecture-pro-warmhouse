{"openapi":"3.1.0","info":{"title":"Device Management Service API","description":"API для управления IoT устройствами умного дома","version":"1.0"},"servers":[{"url":"http://localhost:8080","description":"Локальный сервер"}],"tags":[{"name":"Device Status Management","description":"API для управления статусом устройств"}],"paths":{"/api/v1/devices/{deviceId}/status":{"get":{"tags":["Device Status Management"],"summary":"Получить статус устройства","description":"Возвращает текущий статус и информацию об устройстве","operationId":"getDeviceStatus","parameters":[{"name":"deviceId","in":"path","description":"ID устройства","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/DeviceStatusDto"}}}}}},"put":{"tags":["Device Status Management"],"summary":"Обновить статус устройства","description":"Позволяет вручную установить статус устройства","operationId":"updateDeviceStatus","parameters":[{"name":"deviceId","in":"path","description":"ID устройства","required":true,"schema":{"type":"string"}},{"name":"status","in":"query","description":"Новый статус","required":true,"schema":{"type":"string","enum":["ONLINE","OFFLINE","ERROR","MAINTENANCE"]}}],"responses":{"200":{"description":"OK"}}}}},"components":{"schemas":{"DeviceStatusDto":{"type":"object","description":"DTO статуса устройства","properties":{"deviceId":{"type":"string","description":"ID устройства","example":"device-123"},"status":{"type":"string","description":"Статус устройства","example":"ONLINE"},"online":{"type":"boolean","description":"Флаг онлайн статуса"},"lastSeen":{"type":"string","format":"date-time","description":"Время последней активности"},"ipAddress":{"type":"string","description":"IP адрес устройства","example":"192.168.1.100"}}}}}}